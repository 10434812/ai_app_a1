# Server Configuration
PORT=4000
JWT_SECRET=dev_secret_key_123456
# Comma-separated browser origins allowed to call this backend.
# Local Vite dev:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Docker/Nginx sample:
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# Example for production:
# CORS_ORIGIN=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://localhost:3001

# Database Configuration
# 独立起 MySQL 时，用数据库真实地址和端口；常见是 127.0.0.1:3306
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ai_app
DB_PASSWORD=123456
DB_NAME=ai_app

# Redis Configuration
REDIS_URL=redis://:123456@localhost:6379

# LLM API Keys
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=

# WeChat Configuration
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
