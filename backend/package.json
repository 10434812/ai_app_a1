{
  "name": "ai-aggregator-backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:rollback": "tsx src/scripts/migrate-rollback.ts",
    "config:export": "tsx src/scripts/export-config.ts",
    "config:import": "tsx src/scripts/import-config.ts",
    "test": "tsx --test src/tests/**/*.test.ts",
    "test:e2e": "tsx --test src/tests/e2e/**/*.test.ts"
  },
  "dependencies": {
    "@sentry/node": "^9.47.1",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.9.2",
    "qrcode": "^1.5.4",
    "redis": "^4.6.13",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "wechatpay-node-v3": "^2.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookiejar": "^2.1.5",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/methods": "^1.1.4",
    "@types/mime": "^4.0.0",
    "@types/ms": "^2.1.0",
    "@types/mysql": "^2.15.27",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.18.0",
    "@types/pg-pool": "^2.0.7",
    "@types/qs": "^6.15.0",
    "@types/serve-static": "^2.2.0",
    "@types/shimmer": "^1.2.0",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "@types/tedious": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.10",
    "supertest": "^7.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
